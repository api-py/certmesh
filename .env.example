# =============================================================================
# certmesh environment variable reference
# Copy to .env and fill in values for local development.
# NEVER commit a populated .env file to source control.
# =============================================================================

# ---------------------------------------------------------------------------
# HashiCorp Vault — connection
# ---------------------------------------------------------------------------
CM_VAULT_URL=https://vault.example.com
CM_VAULT_TLS_VERIFY=true
CM_VAULT_TIMEOUT=30

# ---------------------------------------------------------------------------
# HashiCorp Vault — authentication (choose ONE)
# ---------------------------------------------------------------------------
CM_VAULT_AUTH_METHOD=approle

# approle
CM_VAULT_ROLE_ID=
CM_VAULT_SECRET_ID=

# ldap
# CM_VAULT_AUTH_METHOD=ldap
# CM_VAULT_LDAP_USERNAME=
# CM_VAULT_LDAP_PASSWORD=

# aws_iam
# CM_VAULT_AUTH_METHOD=aws_iam
# CM_VAULT_AWS_ROLE=certmesh
# CM_VAULT_AWS_MOUNT_POINT=aws

# ---------------------------------------------------------------------------
# HashiCorp Vault — PKI engine
# ---------------------------------------------------------------------------
CM_VAULT_PKI_MOUNT=pki
CM_VAULT_PKI_ROLE=certmesh-issuer
CM_VAULT_PKI_TTL=8760h

# ---------------------------------------------------------------------------
# HashiCorp Vault — KV secret paths
# ---------------------------------------------------------------------------
CM_VAULT_PATH_DIGICERT=secret/certmesh/digicert/api_key
CM_VAULT_PATH_VENAFI=secret/certmesh/venafi/credentials

# ---------------------------------------------------------------------------
# Direct secret injection (bypasses Vault)
# ---------------------------------------------------------------------------
CM_DIGICERT_API_KEY=
CM_VENAFI_USERNAME=
CM_VENAFI_PASSWORD=

# ---------------------------------------------------------------------------
# DigiCert CertCentral
# ---------------------------------------------------------------------------
CM_DIGICERT_BASE_URL=https://www.digicert.com/services/v2
CM_DIGICERT_TIMEOUT=30
CM_DIGICERT_KEY_SIZE=4096
CM_DIGICERT_PRODUCT=ssl_plus

# ---------------------------------------------------------------------------
# Venafi TPP
# ---------------------------------------------------------------------------
CM_VENAFI_BASE_URL=https://venafi.example.com
CM_VENAFI_AUTH_METHOD=oauth
CM_VENAFI_OAUTH_CLIENT_ID=certapi
CM_VENAFI_OAUTH_SCOPE=certificate:manage

# ---------------------------------------------------------------------------
# AWS ACM
# ---------------------------------------------------------------------------
CM_ACM_REGION=us-east-1
CM_ACM_KEY_ALGORITHM=RSA_2048
CM_ACM_VALIDATION_METHOD=DNS
CM_ACM_PCA_ARN=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
CM_LOG_LEVEL=INFO
